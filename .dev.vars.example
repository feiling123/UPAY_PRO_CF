# Required production secrets / variables for Deploy to Cloudflare.
# Use 32-128 printable ASCII characters without whitespace for the three secrets below.
ADMIN_JWT_SECRET=
CONFIG_ENCRYPTION_KEY=
MERCHANT_SIGNING_SECRET=

# Optional values are intentionally not listed here because Deploy to Cloudflare
# currently treats generated fields as required. Configure chain API keys,
# Turnstile, Telegram, and Bark after deployment in the admin console or
# Cloudflare Worker Variables.
